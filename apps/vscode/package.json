{
  "name": "codesetu",
  "displayName": "CodeSetu",
  "description": "Open-source AI coding assistant for VSCode with multi-provider chat and inline completions. Works with Sarvam, OpenAI-compatible APIs, and local models.",
  "version": "0.4.0",
  "publisher": "codesetu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/getcodesetu/codesetu.git",
    "directory": "apps/vscode"
  },
  "bugs": {
    "url": "https://github.com/getcodesetu/codesetu/issues"
  },
  "homepage": "https://github.com/getcodesetu/codesetu#readme",
  "type": "commonjs",
  "main": "./dist/extension.cjs",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "ai",
    "llm",
    "ai-coding-assistant",
    "copilot-alternative",
    "code-completion",
    "chat",
    "inline-completions",
    "fim",
    "sarvam",
    "ollama",
    "openai-compatible",
    "vllm",
    "openrouter",
    "self-hosted",
    "local-llm",
    "air-gapped",
    "on-premise",
    "indic",
    "india",
    "open-source"
  ],
  "galleryBanner": {
    "color": "#5865F2",
    "theme": "dark"
  },
  "qna": "https://discord.gg/sjVKU8cpC6",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codesetu.openChat",
        "title": "CodeSetu: Open Chat",
        "category": "CodeSetu"
      },
      {
        "command": "codesetu.setupProvider",
        "title": "CodeSetu: Setup Provider",
        "category": "CodeSetu"
      },
      {
        "command": "codesetu.diagnoseProvider",
        "title": "CodeSetu: Diagnose Provider",
        "category": "CodeSetu"
      },
      {
        "command": "codesetu.selectModel",
        "title": "CodeSetu: Select Model",
        "category": "CodeSetu"
      },
      {
        "command": "codesetu.explainSelection",
        "title": "Explain with CodeSetu",
        "category": "CodeSetu"
      },
      {
        "command": "codesetu.refactorSelection",
        "title": "Refactor with CodeSetu",
        "category": "CodeSetu"
      },
      {
        "command": "codesetu.writeTestsForSelection",
        "title": "Write Tests with CodeSetu",
        "category": "CodeSetu"
      },
      {
        "command": "codesetu.fixBugInSelection",
        "title": "Fix Bug with CodeSetu",
        "category": "CodeSetu"
      },
      {
        "command": "codesetu.addDocsToSelection",
        "title": "Add Docs with CodeSetu",
        "category": "CodeSetu"
      },
      {
        "command": "codesetu.setupSpeechProvider",
        "title": "CodeSetu: Setup Speech Provider",
        "category": "CodeSetu"
      },
      {
        "command": "codesetu.editSelection",
        "title": "Edit with CodeSetu",
        "category": "CodeSetu"
      },
      {
        "command": "codesetu.revertLastAgentEdits",
        "title": "CodeSetu: Revert Last Agent Edits",
        "category": "CodeSetu"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codesetu.explainSelection",
          "when": "editorHasSelection",
          "group": "1_modification@30"
        },
        {
          "command": "codesetu.refactorSelection",
          "when": "editorHasSelection",
          "group": "1_modification@31"
        },
        {
          "command": "codesetu.writeTestsForSelection",
          "when": "editorHasSelection",
          "group": "1_modification@32"
        },
        {
          "command": "codesetu.fixBugInSelection",
          "when": "editorHasSelection",
          "group": "1_modification@33"
        },
        {
          "command": "codesetu.addDocsToSelection",
          "when": "editorHasSelection",
          "group": "1_modification@34"
        },
        {
          "command": "codesetu.editSelection",
          "when": "editorHasSelection",
          "group": "1_modification@35"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codesetu",
          "title": "CodeSetu",
          "icon": "media/codesetu-activitybar.svg"
        }
      ]
    },
    "views": {
      "codesetu": [
        {
          "id": "codesetuHome",
          "name": "CodeSetu",
          "icon": "media/codesetu-activitybar.svg",
          "contextualTitle": "CodeSetu"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "codesetuHome",
        "contents": "Open-source AI coding assistant. Bring your own model — Sarvam, OpenAI-compatible APIs, or local.\n\n[Open Chat](command:codesetu.openChat)\n\nConfigure providers in [Settings](command:workbench.action.openSettings?%22codesetu%22)."
      }
    ],
    "configuration": {
      "title": "CodeSetu",
      "properties": {
        "codesetu.provider": {
          "type": "string",
          "enum": [
            "sarvam",
            "openai-compatible",
            "huggingface"
          ],
          "enumDescriptions": [
            "Sarvam hosted or compatible endpoint.",
            "Any OpenAI-compatible API (Ollama, vLLM, SGLang, OpenRouter, local).",
            "Hugging Face Inference — the hosted router, a dedicated Inference Endpoint, or self-hosted TGI."
          ],
          "default": "sarvam",
          "description": "Model provider used by CodeSetu."
        },
        "codesetu.apiKey": {
          "type": "string",
          "default": "",
          "markdownDeprecationMessage": "Storing the API key in settings is insecure — it is saved in plaintext and synced by Settings Sync. CodeSetu now keeps it in the OS secret store. Run **CodeSetu: Setup Provider**; any value left here is migrated to secure storage and cleared automatically.",
          "description": "Deprecated. Use the CodeSetu: Setup Provider command (the key is stored in the OS secret store). If empty, CodeSetu reads provider environment variables."
        },
        "codesetu.baseUrl": {
          "type": "string",
          "default": "",
          "description": "OpenAI-compatible base URL. Leave empty for the provider default."
        },
        "codesetu.model": {
          "type": "string",
          "default": "",
          "description": "Model name. Leave empty for the provider default."
        },
        "codesetu.inlineCompletions.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline fill-in-the-middle completions."
        },
        "codesetu.inlineCompletions.maxTokens": {
          "type": "number",
          "default": 96,
          "minimum": 1,
          "maximum": 512,
          "description": "Maximum tokens to request for inline completions."
        },
        "codesetu.inlineCompletions.temperature": {
          "type": "number",
          "default": 0.1,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for inline completions."
        },
        "codesetu.inlineCompletions.maxPrefixChars": {
          "type": "number",
          "default": 4000,
          "minimum": 100,
          "description": "Maximum characters before the cursor sent for FIM completions."
        },
        "codesetu.inlineCompletions.maxSuffixChars": {
          "type": "number",
          "default": 2000,
          "minimum": 0,
          "description": "Maximum characters after the cursor sent for FIM completions."
        },
        "codesetu.inlineCompletions.stopSequences": {
          "type": "array",
          "default": [
            "\n\n",
            "\n```"
          ],
          "items": {
            "type": "string"
          },
          "description": "Stop sequences for inline completions."
        },
        "codesetu.inlineCompletions.debounceMs": {
          "type": "number",
          "default": 200,
          "minimum": 0,
          "maximum": 2000,
          "description": "Delay in milliseconds before requesting an inline completion, so a burst of keystrokes fires only one request."
        },
        "codesetu.chat.maxTokens": {
          "type": "number",
          "default": 4096,
          "minimum": 1,
          "description": "Maximum tokens to request for chat responses."
        },
        "codesetu.chat.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for chat responses."
        },
        "codesetu.skills.autoRoute": {
          "type": "boolean",
          "default": true,
          "description": "Auto-route built-in AI skills (Explain, Refactor, Write Tests, Indic Comments) by matching keywords in your message. Turn off to require slash invocation (e.g. /explain)."
        },
        "codesetu.speech.sttProvider": {
          "type": "string",
          "enum": [
            "browser",
            "sarvam",
            "openai-compatible",
            "huggingface"
          ],
          "enumDescriptions": [
            "Use the browser SpeechRecognition API (no server call). Free, English best, requires Chromium-based VS Code.",
            "Sarvam Saarika hosted STT (Indic languages first-class). Requires a Sarvam API key.",
            "Any OpenAI-compatible endpoint exposing /v1/audio/transcriptions (OpenAI, Groq, local whisper.cpp).",
            "Hugging Face Inference Router (Whisper-large-v3 by default)."
          ],
          "default": "browser",
          "description": "Speech-to-text backend used by the chat mic."
        },
        "codesetu.speech.language": {
          "type": "string",
          "default": "en-US",
          "description": "BCP-47 language code for STT, e.g. en-US, hi-IN, ta-IN, bn-IN."
        },
        "codesetu.speech.sttBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for openai-compatible or huggingface STT (leave empty for provider default)."
        },
        "codesetu.speech.sttModel": {
          "type": "string",
          "default": "",
          "description": "Model id for STT (e.g. whisper-1, openai/whisper-large-v3, saarika:v2). Empty = provider default."
        }
      }
    }
  },
  "scripts": {
    "copy-skills": "node scripts/copy-skills.mjs",
    "build": "node scripts/copy-skills.mjs && esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.cjs --sourcemap",
    "dev": "node scripts/copy-skills.mjs && esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.cjs --sourcemap --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@codesetu/core": "workspace:*",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.5"
  }
}

# CodeSetu on-prem stack configuration. Copy to .env and edit as needed.

# Host port the OpenAI-compatible server listens on. The container always uses
# 11434 internally; this is the host-side mapping.
CODESETU_PORT=11434

# Chat / agent model. For Agent Mode it MUST support tool/function calling.
# Good code models: qwen2.5-coder:7b (or :14b / :32b for more capacity),
# llama3.1:8b. Smaller = faster + less RAM/VRAM.
CHAT_MODEL=qwen2.5-coder:7b

# Embedding model for @workspace semantic indexing.
# Alternatives: mxbai-embed-large, all-minilm.
EMBEDDING_MODEL=nomic-embed-text
